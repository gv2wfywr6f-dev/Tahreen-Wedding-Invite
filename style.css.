@import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600&family=Poppins:wght@300;400;500&display=swap');

*{
margin:0;
padding:0;
box-sizing:border-box;
}

html{
scroll-behavior:smooth;
}

body{

font-family:'Poppins',sans-serif;

background:#fdf8ef;

color:#4d3b2a;

overflow-x:hidden;

}

/* Background */

body::before{

content:"";

position:fixed;

inset:0;

background:

radial-gradient(circle at top,#fff9ef,#f7eddc);

z-index:-2;

}

body::after{

content:"☾";

position:fixed;

top:30px;

right:40px;

font-size:90px;

opacity:.08;

color:#b68b2b;

z-index:-1;

}

/* Hero */

.hero{

height:100vh;

display:flex;

justify-content:center;

align-items:center;

text-align:center;

padding:20px;

background:

linear-gradient(rgba(255,250,242,.82),

rgba(255,250,242,.82)),

url("images/mosque-bg.jpg");

background-size:cover;

background-position:center;

}

.hero-content{

max-width:700px;

animation:fadeUp 1.5s ease;

}

.hero h3{

font-size:28px;

color:#b68b2b;

margin-bottom:20px;

}

.hero h1{

font-family:'Cinzel',serif;

font-size:70px;

color:#7b5b26;

}

.hero span{

color:#c8a243;

}

.subtitle{

margin-top:25px;

font-size:20px;

line-height:1.8;

}

.btn{

display:inline-block;

margin-top:40px;

padding:15px 38px;

background:#b68b2b;

color:#fff;

text-decoration:none;

border-radius:50px;

transition:.3s;

font-weight:500;

}

.btn:hover{

background:#8d6a17;

transform:translateY(-4px);

}

/* Sections */

section{

padding:90px 20px;

text-align:center;

}

section h2{

font-family:'Cinzel',serif;

font-size:40px;

color:#8a6423;

margin-bottom:25px;

}

/* Quran */

.verse{

max-width:900px;

margin:auto;

font-size:20px;

line-height:2;

}

/* Couple */

.couple img{

width:320px;

max-width:90%;

border-radius:25px;

box-shadow:0 20px 45px rgba(0,0,0,.15);

}

/* Cards */

.details{

display:flex;

gap:25px;

justify-content:center;

flex-wrap:wrap;

}

.card{

background:white;

padding:35px;

width:280px;

border-radius:25px;

box-shadow:0 10px 35px rgba(0,0,0,.08);

transition:.4s;

}

.card:hover{

transform:translateY(-8px);

}

.card h3{

color:#b68b2b;

margin-bottom:15px;

}

/* Countdown */

.countdown{

background:#fffaf3;

}

#timer{

display:flex;

justify-content:center;

gap:20px;

flex-wrap:wrap;

}

#timer div{

background:white;

padding:25px;

border-radius:20px;

width:120px;

box-shadow:0 10px 25px rgba(0,0,0,.08);

}

#timer span{

font-size:40px;

font-weight:bold;

color:#b68b2b;

display:block;

}

/* Dua */

.dua h3{

font-size:34px;

margin-bottom:25px;

color:#8b6a26;

line-height:1.8;

}

/* RSVP */

.rsvp{

background:#fff8ec;

}

/* Footer */

footer{

padding:35px;

background:#7d5c22;

color:white;

text-align:center;

}

/* Animation */

@keyframes fadeUp{

from{

opacity:0;

transform:translateY(50px);

}

to{

opacity:1;

transform:translateY(0);

}

}

/* Mobile */

@media(max-width:768px){

.hero h1{

font-size:48px;

}

.hero h3{

font-size:22px;

}

.subtitle{

font-size:17px;

}

section h2{

font-size:32px;

}

}